import java.util.*;

public class Main {

    public static void main(String[] args){

        Scanner sc=new Scanner(System.in);

        int n=sc.nextInt();

        long ans=0;

        long max=sc.nextLong();

        boolean positive=max>0;

        for(int i=1;i<n;i++){

            long x=sc.nextLong();

            if((x>0)==positive){
                max=Math.max(max,x);
            }
            else{
                ans+=max;
                max=x;
                positive=x>0;
            }
        }

        ans+=max;

        System.out.println(ans);
    }
}
