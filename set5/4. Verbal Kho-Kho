import java.util.*;

public class Main {
    public static void main(String[] args){

        Scanner sc=new Scanner(System.in);

        int n=sc.nextInt();

        int[] arr=new int[n];

        for(int i=0;i<n;i++)
            arr[i]=sc.nextInt();

        int last=arr[n-1];

        int count=0;

        for(int i=0;i<n-1;i++){
            if(arr[i]!=last)
                count++;
        }

        System.out.println(count);
    }
}
