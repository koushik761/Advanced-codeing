import java.util.*;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int n = sc.nextInt();
        int[] arr = new int[n];

        for(int i=0;i<n;i++)
            arr[i]=sc.nextInt();

        int d=sc.nextInt();
        int x=sc.nextInt();

        int fine=0;

        for(int num:arr){
            if(d%2==0){
                if(num%2!=0)
                    fine+=x;
            }
            else{
                if(num%2==0)
                    fine+=x;
            }
        }

        System.out.println(fine);
    }
}
